/*
 * Keymap dla Dactyl Manuform 6x6 (7 wierszy × 6 kolumn per half)
 * ================================================================
 * Razem 84 klawisze (7 wierszy × 12 kolumn logicznych)
 *
 * Fizyczny układ wierszy:
 *   Row 0 – D10 – rząd cyfr
 *   Row 1 – D16 – litery górne (Q W E R T ...)
 *   Row 2 – D14 – litery środkowe (A S D F G ...)
 *   Row 3 – D15 – litery dolne (Z X C V B ...)
 *   Row 4 – D19 – modyfikatory + Backspace/Space
 *   Row 5 – D20 – klaster kciuka górny
 *   Row 6 – D21 – klaster kciuka dolny
 *
 * Warstwy:
 *   0 – QWERTY (podstawowa)
 *   1 – LOWER  (symbole, F1–F12)
 *   2 – RAISE  (nawigacja, media)
 *   3 – ADJUST (Bluetooth, reset)
 *
 * UWAGA: Wiersze 5 i 6 (klaster kciuka) mają &none na pozycjach
 * bez fizycznego klawisza. Dostosuj do swojego budowania.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define L_BASE   0
#define L_LOWER  1
#define L_RAISE  2
#define L_ADJUST 3

/ {
    keymap {
        compatible = "zmk,keymap";

        /* ══════════════════════════════════════════════════════════════════
         * WARSTWA 0 – QWERTY
         * ══════════════════════════════════════════════════════════════════
         *
         * Row↑=D21 … Row↓=D10  (Row 6 = fizyczny TOP, Row 0 = fizyczny BOT/kciuk)
         *
         *      ── LEWA (outer→inner) ──────────────────────────── PRAWA (inner→outer) ──
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │  F1  │  F2  │  F3  │  F4  │  F5  │  F6  │   │  F7  │  F8  │  F9  │  F10 │  F11 │  F12 │ Row6 D21↑ TOP
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ Esc  │  1   │  2   │  3   │  4   │  5   │   │  6   │  7   │  8   │  9   │  0   │  -   │ Row5 D20
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │  `   │  Q   │  W   │  E   │  R   │  T   │   │  Y   │  U   │  I   │  O   │  P   │  =   │ Row4 D19
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ Tab  │  A   │  S   │  D   │  F   │  G   │   │  H   │  J   │  K   │  L   │  ;   │  '   │ Row3 D15
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │LShft │  Z   │  X   │  C   │  V   │  B   │   │  N   │  M   │  ,   │  .   │  /   │RShft │ Row2 D14
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ End  │Home  │ Del  │ LAlt │ LGUI │Ra+Rt │   │ Spc  │Lo+Bs │^PgUp │ PgDn │  [   │  ]   │ Row1 D16 kciuk↑
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │      │ Ent  │LShft │ LAlt │ LGUI │   │ LAlt │ LGUI │RShft │ Ent  │      │      │ Row0 D10↓ kciuk↓
         * └──────┴──────┴──────┴──────┴──────┴──────┘   └──────┴──────┴──────┴──────┴──────┴──────┘
         */
        default_layer {
            label = "QWERTY";
            bindings = <
/* ──── Prawa (pos 0-5: inner→outer) ──────────────── Lewa (pos 6-11: inner→outer) ── */
/* Row0 kciuk dół   */ &kp LALT  &kp LGUI  &kp RSHFT &kp RET   &none    &none      &kp LGUI  &kp LALT  &kp LSHFT &kp RET   &none    &none
/* Row1 kciuk górny */ &kp SPACE &lt L_LOWER BSPC &mt RCTRL PG_UP &kp PG_DN &kp LBKT &kp RBKT   &lt L_RAISE RET &kp LGUI &kp LALT  &kp DEL   &kp HOME &kp END
/* Row2 N/B-rząd    */ &kp N     &kp M     &kp COMMA &kp DOT   &kp FSLH &kp RSHFT  &kp B     &kp V     &kp C     &kp X     &kp Z    &kp LSHFT
/* Row3 H/G-rząd    */ &kp H     &kp J     &kp K     &kp L     &kp SEMI &kp SQT    &kp G     &kp F     &kp D     &kp S     &kp A    &kp TAB
/* Row4 Y/T-rząd    */ &kp Y     &kp U     &kp I     &kp O     &kp P    &kp EQUAL  &kp T     &kp R     &kp E     &kp W     &kp Q    &kp GRAVE
/* Row5 cyfry        */ &kp N6    &kp N7    &kp N8    &kp N9    &kp N0   &kp MINUS  &kp N5    &kp N4    &kp N3    &kp N2    &kp N1   &kp ESC
/* Row6 F-rząd (TOP)*/ &kp F7    &kp F8    &kp F9    &kp F10   &kp F11  &kp F12    &kp F6    &kp F5    &kp F4    &kp F3    &kp F2   &kp F1
            >;
        };

        /* ══════════════════════════════════════════════════════════════════
         * WARSTWA 1 – LOWER (symbole, F1–F12)
         * ══════════════════════════════════════════════════════════════════
         */
        lower_layer {
            label = "LOWER";
            bindings = <
                &kp TILDE   &kp F1    &kp F2    &kp F3    &kp F4     &kp F5        &kp F6    &kp F7    &kp F8    &kp F9    &kp F10   &kp F11
                &trans      &kp EXCL  &kp AT    &kp HASH  &kp DLLR   &kp PRCNT     &kp CARET &kp AMPS  &kp STAR  &kp LPAR  &kp RPAR  &kp F12
                &trans      &kp N1    &kp N2    &kp N3    &kp N4     &kp N5        &kp N6    &kp N7    &kp N8    &kp N9    &kp N0    &kp PLUS
                &trans      &trans    &trans    &kp UNDER &kp MINUS  &kp LBKT      &kp RBKT  &kp EQUAL &kp LBRC  &kp RBRC  &kp PIPE  &trans
                &trans      &trans    &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &trans    &trans
                &mo L_ADJUST &trans  &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &trans    &mo L_ADJUST
                &trans      &trans    &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &trans    &trans
            >;
        };

        /* ══════════════════════════════════════════════════════════════════
         * WARSTWA 2 – RAISE (nawigacja, media)
         * ══════════════════════════════════════════════════════════════════
         */
        raise_layer {
            label = "RAISE";
            bindings = <
                &trans      &trans    &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &trans       &trans
                &trans      &trans    &trans    &trans    &trans     &trans        &kp PG_UP &kp HOME  &kp UP    &kp END   &kp INS      &kp DEL
                &trans      &trans    &trans    &trans    &trans     &trans        &kp PG_DN &kp LEFT  &kp DOWN  &kp RIGHT &kp BSPC     &trans
                &trans      &trans    &trans    &trans    &trans     &trans        &trans    &kp C_PREV &kp C_PP &kp C_NEXT &kp C_VOL_DN &kp C_VOL_UP
                &trans      &trans    &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &kp C_MUTE   &trans
                &trans      &trans    &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &trans       &trans
                &mo L_ADJUST &trans  &trans    &trans    &trans     &trans        &trans    &trans    &trans    &trans    &trans       &mo L_ADJUST
            >;
        };

        /* ══════════════════════════════════════════════════════════════════
         * WARSTWA 3 – ADJUST (Bluetooth, reset)
         * Aktywacja: trzymaj LOWER + RAISE jednocześnie
         * studio_unlock: Row1 pos1 (kciuk górny, drugi od środka prawej ręki)
         * ══════════════════════════════════════════════════════════════════
         */
        adjust_layer {
            label = "ADJUST";
            bindings = <
                &sys_reset  &bt BT_CLR   &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3    &bt BT_SEL 4 &none  &none  &none  &none  &sys_reset
                &bootloader &studio_unlock &none      &none        &none        &none           &none        &none  &none  &none  &none  &bootloader
                &out OUT_USB &none       &none        &none        &none        &none           &none        &none  &none  &none  &none  &out OUT_BLE
                &none       &none        &none        &none        &none        &none           &none        &none  &none  &none  &none  &none
                &trans      &none        &none        &none        &none        &none           &none        &none  &none  &none  &none  &trans
                &trans      &none        &none        &none        &none        &none           &none        &none  &none  &none  &none  &trans
                &none       &none        &none        &none        &none        &none           &none        &none  &none  &none  &none  &none
            >;
        };
    };
};
