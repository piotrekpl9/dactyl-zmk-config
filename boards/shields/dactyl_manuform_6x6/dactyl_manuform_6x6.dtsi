/*
 * Dactyl Manuform 6x6 – wspólna definicja tarczy (DTSI)
 *
 * Układ: 6 kolumn × 7 wierszy na każdą połowę = 42 klawisze / strona
 * Razem: 84 klawisze (12 kolumn logicznych × 7 wierszy)
 *
 * Role:
 *   Lewa  połowa = CENTRAL  (łączy się z komputerem, obsługuje ZMK Studio)
 *   Prawa połowa = PERIPHERAL (skanuje lokalnie, wysyła przez BLE do lewej)
 *
 * Mapowanie kolumn w macierzy ZMK:
 *   Lewa  (central,    cols 0-5):  D4(c0,inner) D6(c1) D5(c2) D7(c3) D8(c4) D9(c5,outer)
 *   Prawa (peripheral, cols 6-11): D9(c6,outer) D8(c7) D7(c8) D5(c9) D4(c10,inner) D6(c11)
 *
 * Wiersze: Row0=D10(dolny/kciuk) … Row6=D21(górny/F-klawisze)
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
    };

    /*
     * Transformacja macierzy 7 wierszy × 12 kolumn = 84 klawisze.
     *
     * Pierwsze 6 pozycji w wierszu = prawa strona (peripheral, cols 6-11):
     *   RC(r,10) RC(r,11) RC(r,9) RC(r,8) RC(r,7) RC(r,6)
     *   = D4(inner) D6  D5  D7  D8  D9(outer)
     *
     * Ostatnie 6 pozycji w wierszu = lewa strona (central, cols 0-5):
     *   RC(r,0) RC(r,1) RC(r,2) RC(r,3) RC(r,4) RC(r,5)
     *   = D4(inner) D6  D5  D7  D8  D9(outer)
     */
    /*
     * Transformacja dla lewej połowy (central, cols 0-5).
     * Prawa połowa (peripheral) ma osobną transformację w right.overlay z col-offset=6.
     *
     * Kolejność pozycji w keymapie (każdy wiersz, 12 klawiszy):
     *   pos 0-5  = prawa strona: inner(D4)→D6→D5→D7→D8→outer(D9)
     *   pos 6-11 = lewa strona:  inner(D4)→D6→D5→D7→D8→outer(D9)
     *
     * Prawa cols po col-offset=6: lokalny col0→global6, col1→7, col2→8, col3→9, col4→10, col5→11
     * Kolejność prawej w overlay: D9(col0), D8(col1), D7(col2), D5(col3), D4(col4), D6(col5)
     * → global: D9=6, D8=7, D7=8, D5=9, D4=10, D6=11
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <7>;
        map = <
            RC(0,10) RC(0,11) RC(0,9) RC(0,8) RC(0,7) RC(0,6)   RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
            RC(1,10) RC(1,11) RC(1,9) RC(1,8) RC(1,7) RC(1,6)   RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
            RC(2,10) RC(2,11) RC(2,9) RC(2,8) RC(2,7) RC(2,6)   RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
            RC(3,10) RC(3,11) RC(3,9) RC(3,8) RC(3,7) RC(3,6)   RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
            RC(4,10) RC(4,11) RC(4,9) RC(4,8) RC(4,7) RC(4,6)   RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)
            RC(5,10) RC(5,11) RC(5,9) RC(5,8) RC(5,7) RC(5,6)   RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5)
            RC(6,10) RC(6,11) RC(6,9) RC(6,8) RC(6,7) RC(6,6)   RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4) RC(6,5)
        >;
    };

    /*
     * Transformacja dla prawej połowy (peripheral).
     * col-offset=6: lokalny col N → globalny col N+6
     * Cols w overlay: D9(0→6), D8(1→7), D7(2→8), D5(3→9), D4(4→10), D6(5→11)
     */
    right_transform: keymap_transform_1 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <7>;
        col-offset = <6>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)
            RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5)
            RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4) RC(6,5)
        >;
    };

    /*
     * Fizyczny układ klawiszy dla ZMK Studio.
     * Jednostka: centi-keyunit (100 = 1U).
     * Format: <&key_physical_attrs w h x y r rx ry>
     *
     * Kolejność wpisów = kolejność pozycji w keymapie (0–83):
     *   pos 0-5  = prawa strona, inner→outer, x=700…1200
     *   pos 6-11 = lewa strona,  inner→outer, x=500…0
     *
     * Wiersze (y):
     *   Row 0 kciuk dół   → y=600
     *   Row 1 kciuk górny → y=500
     *   Row 2 N/B-rząd    → y=400
     *   Row 3 H/G-rząd    → y=300
     *   Row 4 Y/T-rząd    → y=200
     *   Row 5 cyfry        → y=100
     *   Row 6 F-klawisze  → y=0
     */
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Dactyl MF 6x6";
        transform = <&default_transform>;
        keys =
            /* ── Row 0: kciuk dół ─────────────────────────────────────── */
            /* prawa strona (inner→outer, x=700…1200) */
              <&key_physical_attrs 100 100  700 600 0 0 0>
            , <&key_physical_attrs 100 100  800 600 0 0 0>
            , <&key_physical_attrs 100 100  900 600 0 0 0>
            , <&key_physical_attrs 100 100 1000 600 0 0 0>
            , <&key_physical_attrs 100 100 1100 600 0 0 0>
            , <&key_physical_attrs 100 100 1200 600 0 0 0>
            /* lewa strona (inner→outer, x=500…0) */
            , <&key_physical_attrs 100 100  500 600 0 0 0>
            , <&key_physical_attrs 100 100  400 600 0 0 0>
            , <&key_physical_attrs 100 100  300 600 0 0 0>
            , <&key_physical_attrs 100 100  200 600 0 0 0>
            , <&key_physical_attrs 100 100  100 600 0 0 0>
            , <&key_physical_attrs 100 100    0 600 0 0 0>
            /* ── Row 1: kciuk górny ────────────────────────────────────── */
            , <&key_physical_attrs 100 100  700 500 0 0 0>
            , <&key_physical_attrs 100 100  800 500 0 0 0>
            , <&key_physical_attrs 100 100  900 500 0 0 0>
            , <&key_physical_attrs 100 100 1000 500 0 0 0>
            , <&key_physical_attrs 100 100 1100 500 0 0 0>
            , <&key_physical_attrs 100 100 1200 500 0 0 0>
            , <&key_physical_attrs 100 100  500 500 0 0 0>
            , <&key_physical_attrs 100 100  400 500 0 0 0>
            , <&key_physical_attrs 100 100  300 500 0 0 0>
            , <&key_physical_attrs 100 100  200 500 0 0 0>
            , <&key_physical_attrs 100 100  100 500 0 0 0>
            , <&key_physical_attrs 100 100    0 500 0 0 0>
            /* ── Row 2: N/B-rząd ───────────────────────────────────────── */
            , <&key_physical_attrs 100 100  700 400 0 0 0>
            , <&key_physical_attrs 100 100  800 400 0 0 0>
            , <&key_physical_attrs 100 100  900 400 0 0 0>
            , <&key_physical_attrs 100 100 1000 400 0 0 0>
            , <&key_physical_attrs 100 100 1100 400 0 0 0>
            , <&key_physical_attrs 100 100 1200 400 0 0 0>
            , <&key_physical_attrs 100 100  500 400 0 0 0>
            , <&key_physical_attrs 100 100  400 400 0 0 0>
            , <&key_physical_attrs 100 100  300 400 0 0 0>
            , <&key_physical_attrs 100 100  200 400 0 0 0>
            , <&key_physical_attrs 100 100  100 400 0 0 0>
            , <&key_physical_attrs 100 100    0 400 0 0 0>
            /* ── Row 3: H/G-rząd ───────────────────────────────────────── */
            , <&key_physical_attrs 100 100  700 300 0 0 0>
            , <&key_physical_attrs 100 100  800 300 0 0 0>
            , <&key_physical_attrs 100 100  900 300 0 0 0>
            , <&key_physical_attrs 100 100 1000 300 0 0 0>
            , <&key_physical_attrs 100 100 1100 300 0 0 0>
            , <&key_physical_attrs 100 100 1200 300 0 0 0>
            , <&key_physical_attrs 100 100  500 300 0 0 0>
            , <&key_physical_attrs 100 100  400 300 0 0 0>
            , <&key_physical_attrs 100 100  300 300 0 0 0>
            , <&key_physical_attrs 100 100  200 300 0 0 0>
            , <&key_physical_attrs 100 100  100 300 0 0 0>
            , <&key_physical_attrs 100 100    0 300 0 0 0>
            /* ── Row 4: Y/T-rząd ───────────────────────────────────────── */
            , <&key_physical_attrs 100 100  700 200 0 0 0>
            , <&key_physical_attrs 100 100  800 200 0 0 0>
            , <&key_physical_attrs 100 100  900 200 0 0 0>
            , <&key_physical_attrs 100 100 1000 200 0 0 0>
            , <&key_physical_attrs 100 100 1100 200 0 0 0>
            , <&key_physical_attrs 100 100 1200 200 0 0 0>
            , <&key_physical_attrs 100 100  500 200 0 0 0>
            , <&key_physical_attrs 100 100  400 200 0 0 0>
            , <&key_physical_attrs 100 100  300 200 0 0 0>
            , <&key_physical_attrs 100 100  200 200 0 0 0>
            , <&key_physical_attrs 100 100  100 200 0 0 0>
            , <&key_physical_attrs 100 100    0 200 0 0 0>
            /* ── Row 5: cyfry ──────────────────────────────────────────── */
            , <&key_physical_attrs 100 100  700 100 0 0 0>
            , <&key_physical_attrs 100 100  800 100 0 0 0>
            , <&key_physical_attrs 100 100  900 100 0 0 0>
            , <&key_physical_attrs 100 100 1000 100 0 0 0>
            , <&key_physical_attrs 100 100 1100 100 0 0 0>
            , <&key_physical_attrs 100 100 1200 100 0 0 0>
            , <&key_physical_attrs 100 100  500 100 0 0 0>
            , <&key_physical_attrs 100 100  400 100 0 0 0>
            , <&key_physical_attrs 100 100  300 100 0 0 0>
            , <&key_physical_attrs 100 100  200 100 0 0 0>
            , <&key_physical_attrs 100 100  100 100 0 0 0>
            , <&key_physical_attrs 100 100    0 100 0 0 0>
            /* ── Row 6: F-klawisze (TOP) ───────────────────────────────── */
            , <&key_physical_attrs 100 100  700   0 0 0 0>
            , <&key_physical_attrs 100 100  800   0 0 0 0>
            , <&key_physical_attrs 100 100  900   0 0 0 0>
            , <&key_physical_attrs 100 100 1000   0 0 0 0>
            , <&key_physical_attrs 100 100 1100   0 0 0 0>
            , <&key_physical_attrs 100 100 1200   0 0 0 0>
            , <&key_physical_attrs 100 100  500   0 0 0 0>
            , <&key_physical_attrs 100 100  400   0 0 0 0>
            , <&key_physical_attrs 100 100  300   0 0 0 0>
            , <&key_physical_attrs 100 100  200   0 0 0 0>
            , <&key_physical_attrs 100 100  100   0 0 0 0>
            , <&key_physical_attrs 100 100    0   0 0 0 0>
            ;
    };
};
