/*
 * Dactyl Manuform 6x6 – wspólna definicja tarczy (DTSI)
 *
 * Układ: 6 kolumn × 7 wierszy na każdą połowę = 42 klawisze / strona
 * Razem: 84 klawisze (12 kolumn logicznych × 7 wierszy)
 *
 * Transformacja macierzy:
 *   Lewa  połowa → kolumny 0–5   (Col0 = skrajny lewy klawisz)
 *   Prawa połowa → kolumny 6–11  (Col5 = środkowy, Col0 = skrajny prawy)
 *
 * Układ fizyczny (jeden wiersz, czytany od lewa do prawa):
 *   [L0][L1][L2][L3][L4][L5]   [R5][R4][R3][R2][R1][R0]
 *   RC(r,0)..RC(r,5)            RC(r,11)..RC(r,6)
 *
 * Prawa połowa jest okablowana lustrzanie – Col0 prawej = skrajny prawy klawisz.
 * Transformacja odwraca kolejność kolumn 6–11.
 *
 * Okablowanie:
 *   Wiersze: prawa strona nice!nano (D10…D21)
 *   Kolumny: lewa  strona nice!nano (D3, D4, D5, D7, D8, D9)
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    /*
     * Transformacja macierzy 7 wierszy × 12 kolumn = 84 klawisze.
     *
     * Legenda wierszy (Row 0 = D10, Row 6 = D21):
     *   Row 0 – rząd cyfr      (`, 1–5  |  6–0, -)
     *   Row 1 – QWERTY górny   (Tab, Q–T  |  Y–P, \)
     *   Row 2 – QWERTY środk.  (Caps, A–G  |  H–', ')
     *   Row 3 – QWERTY dolny   (LShft, Z–B  |  N–/, RShft)
     *   Row 4 – modyfikatory   (Layer,GUI,Alt,Ctrl,=,Bspc  |  Spc,Ret,Ctrl,Alt,GUI,Layer)
     *   Row 5 – kciuk górny    (klaster kciuka, górny rząd)
     *   Row 6 – kciuk dolny    (klaster kciuka, dolny rząd)
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <7>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)    RC(0,11) RC(0,10) RC(0,9)  RC(0,8)  RC(0,7)  RC(0,6)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)    RC(1,11) RC(1,10) RC(1,9)  RC(1,8)  RC(1,7)  RC(1,6)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)    RC(2,11) RC(2,10) RC(2,9)  RC(2,8)  RC(2,7)  RC(2,6)
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)    RC(3,11) RC(3,10) RC(3,9)  RC(3,8)  RC(3,7)  RC(3,6)
            RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)    RC(4,11) RC(4,10) RC(4,9)  RC(4,8)  RC(4,7)  RC(4,6)
            RC(5,0)  RC(5,1)  RC(5,2)  RC(5,3)  RC(5,4)  RC(5,5)    RC(5,11) RC(5,10) RC(5,9)  RC(5,8)  RC(5,7)  RC(5,6)
            RC(6,0)  RC(6,1)  RC(6,2)  RC(6,3)  RC(6,4)  RC(6,5)    RC(6,11) RC(6,10) RC(6,9)  RC(6,8)  RC(6,7)  RC(6,6)
        >;
    };
};
